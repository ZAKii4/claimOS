# ==========================================
# claimOS - Enterprise Environment Variables
# ==========================================

# 1. Platform Settings
ENVIRONMENT=production
LOG_LEVEL=INFO
SECRET_KEY=generate_a_very_secure_random_string_here_for_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 2. Database (PostgreSQL)
POSTGRES_DB=claimos_db
POSTGRES_PASSWORD=secure_postgres_password_123

# 3. Redis (Cache & PubSub)
REDIS_PASSWORD=secure_redis_password_123

# 4. Neo4j (Knowledge Graph)
NEO4J_PASSWORD=secure_neo4j_password_123

# 5. Local AI (Ollama)
OLLAMA_MODELS_PATH=/models

# 6. Frontend
NEXT_PUBLIC_API_URL=http://localhost/api/v1
