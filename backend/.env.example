# =============================================================================
# claimOS — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit the .env file to version control.
# =============================================================================

# ---- Application -----------------------------------------------------------
APP_NAME=claimOS
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG
ENVIRONMENT=development

# ---- Database (PostgreSQL) --------------------------------------------------
DATABASE_URL=postgresql+psycopg://claimsuser:changeme@localhost:5432/claimsdb

# ---- API --------------------------------------------------------------------
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---- File Storage -----------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ---- Security (MVP stubs — replace for production) -------------------------
# SECRET_KEY=your-secret-key-here
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
